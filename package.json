    "svelte": "^5.56.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-svelte": "^3.22.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.0.0",
    "prettier": "^3.9.6",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte-check": "^4.7.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.12.0"
  }
